[build-system]
requires = [
    "poetry-core>=1.7.0",
    "poetry-dynamic-versioning>=1.0.0,<2.0.0",
]
build-backend = "poetry_dynamic_versioning.backend"


[tool.poetry]
name = "hiveio-api"
version = "0.0.0"
description = "Hive JSON-RPC API client package with lazy-loaded submodules for all Hive APIs"
authors = []
package-mode = true
readme = "hiveio_api/README.md"

packages = [
    { include = "hiveio_api" },
]
include = [
    { path = "hiveio_api/**/*", format = ["wheel", "sdist"] }
]

[[tool.poetry.source]]
name = "PyPI"
priority = "primary"

[[tool.poetry.source]]
name = "gitlab-schemas"
url = "https://gitlab.syncad.com/api/v4/projects/362/packages/pypi/simple"
priority = "supplemental"

[[tool.poetry.source]]
name = "gitlab-beekeepy"
url = "https://gitlab.syncad.com/api/v4/projects/558/packages/pypi/simple"
priority = "supplemental"

[tool.poetry.dependencies]
python = ">=3.12,<4"
hiveio-beekeepy = "{{ api_generation_pyproject.tool.poetry.dependencies['hiveio-beekeepy'] }}"

[tool.poetry-dynamic-versioning]
enable = true
pattern = '''^v?(?P<base>\d+\.\d+\.\d+)(?:(?P<stage>[a-zA-Z]+)(?P<revision>\d+))?$'''
format-jinja = """
{% raw %}
    {%- set dirty_postfix = '.dirty' if dirty else '' -%}
    {%- if distance == 0 and not dirty -%}
        {{ serialize_pep440(base, stage, revision) }}
    {%- elif revision is not none -%}
        {{ serialize_pep440(base, stage, revision + 1, dev=distance, metadata=[commit]) }}{{ dirty_postfix }}
    {%- else -%}
        {{ serialize_pep440(bump_version(base), stage, revision, dev=distance, metadata=[commit]) }}{{ dirty_postfix }}
    {%- endif -%}
{% endraw %}
"""

[tool.poetry-dynamic-versioning.substitution]
files = [
    "hiveio_api/__init__.py",
]
