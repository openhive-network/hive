[build-system]
requires = [
    "poetry-core>=1.7.0",
    "poetry-dynamic-versioning>=1.0.0,<2.0.0",
]
build-backend = "poetry_dynamic_versioning.backend"


[tool.poetry]
name = "hiveio-api"
version = "0.0.0"
description = "Hive JSON-RPC API client package with lazy-loaded submodules for all Hive APIs"
authors = []
package-mode = true
readme = "hiveio_api/README.md"

packages = [
    { include = "hiveio_api" },
]
include = [
    { path = "hiveio_api/**/*", format = ["wheel", "sdist"] }
]

source = [
    { name = "PyPI", priority = "primary" },
    { name = "gitlab-hive", url = "https://gitlab.syncad.com/api/v4/groups/136/-/packages/pypi/simple", priority = "primary" },
]

[tool.poetry.dependencies]
python = ">=3.12,<4"
hiveio-beekeepy = "{{ api_generation_pyproject.tool.poetry.dependencies['hiveio-beekeepy'] }}"

[tool.poetry-dynamic-versioning]
enable = true
pattern = "default-unprefixed"
# PEP 440 compliant versioning with .post{timestamp}
# https://peps.python.org/pep-0440/
#
# Version examples (assuming last tag is 1.2.3rc1):
#   Tag (distance=0, clean):       1.2.3rc1
#   Tag (distance=0, dirty):       1.2.3rc1+dirty
#   develop (distance>0):          1.2.3rc1.post20260129082556
#   develop (dirty):               1.2.3rc1.post20260129082556+dirty
#   feature branch (distance>0):   1.2.3rc1.post20260129082556.dev0+unstable
#   feature branch (dirty):        1.2.3rc1.post20260129082556.dev0+unstable.dirty
#   feature branch (distance=0):   1.2.3rc1  (same as tag)
#
# Logic:
#   - distance=0         -> exact tag version
#   - distance>0, stable -> tag + .post{timestamp}
#   - distance>0, unstable -> tag + .post{timestamp}.dev0+unstable (pre-release, ignored by default)
#   - dirty              -> + 'dirty' marker
#   - unstable           -> + 'unstable' marker
#
# Stability detection:
#   - stable: develop/master/main branches OR tag checkout (detached HEAD with distance=0)
#   - unstable: feature branches OR detached HEAD with distance>0
#   - CI: GitLab checks out as detached HEAD, so branch is None;
#     use CI_COMMIT_REF_NAME env var as fallback for branch detection
#
# Version ordering (newest last):
#   1.2.3rc1 < 1.2.3rc1.post20260129082556 < 1.2.3rc1.post20260129083000.dev0+unstable < 1.2.3rc1.post20260129083000
#   (tag)      (develop)                     (feature, newer timestamp)                  (develop, same timestamp)
#
# pip/poetry behavior:
#   - `poetry update` / `pip install pkg>=1.0` -> selects stable only (ignores .dev0)
#   - `pip install --pre` / `allow-prereleases = true` -> includes feature branches
format-jinja = """
{% raw %}
    {%- set STABLE_BRANCHES = ['develop', 'master', 'main'] -%}

    {%- set effective_branch = branch or env.get('CI_COMMIT_REF_NAME') -%}
    {%- set is_on_tag = distance == 0 -%}
    {%- set is_after_tag = distance > 0 -%}
    {%- set is_tag_checkout = branch is none and is_on_tag -%}
    {%- set is_stable = effective_branch in STABLE_BRANCHES or is_tag_checkout -%}
    {%- set is_feature_branch = is_after_tag and not is_stable -%}

    {%- set post = timestamp|int if is_after_tag else none -%}
    {%- set dev = 0 if is_feature_branch else none -%}
    {%- set local_parts = ['unstable'] if is_feature_branch else [] -%}
    {%- set local_parts = local_parts + ['dirty'] if dirty else local_parts -%}

    {{- serialize_pep440(base, stage, revision, post=post, dev=dev, metadata=local_parts) -}}
{% endraw %}
"""

[tool.poetry-dynamic-versioning.substitution]
files = [
    "hiveio_api/__init__.py",
]
